{
  "name": "watchdeck",
  "version": "0.1.0",
  "description": "Self-hosted endpoint monitoring toolkit for solo devs and small teams",
  "type": "module",
  "bin": {
    "watchdeck": "dist/bin/cli.js"
  },
  "exports": {
    "./dashboard": {
      "import": "./dist/dashboard-mount/index.js",
      "default": "./dist/dashboard-mount/index.js"
    },
    "./dashboard/styles.css": "./dist/dashboard-mount/styles.css"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rimraf dist/bin dist/templates dist/storage && tsup --config config/tsup.config.ts && copyfiles -u 1 \"src/templates/**/*\" dist && copyfiles -u 1 \"src/storage/postgres/migrations/*.sql\" dist",
    "build:dashboard": "rimraf dist/dashboard && vite build",
    "build:dashboard-lib": "rimraf dist/dashboard-mount && vite build --config vite.lib.config.ts",
    "build:all": "npm run build && npm run build:dashboard && npm run build:dashboard-lib",
    "dev": "tsup --config config/tsup.config.ts --watch",
    "start": "node dist/bin/cli.js start",
    "lint": "eslint --config config/eslint.config.js src",
    "format": "prettier --write src",
    "test": "tsx tests/step-5-event-bus.test.ts && tsx tests/step-6-buffer.test.ts && tsx tests/step-7-check-engine.test.ts && tsx tests/step-8-api-server.test.ts && tsx tests/step-9-sse.test.ts && tsx tests/assertions-eval.test.ts && tsx tests/effective-defaults.test.ts"
  },
  "keywords": [
    "monitoring",
    "uptime",
    "endpoint",
    "self-hosted",
    "ssl",
    "incidents",
    "alerts",
    "discord",
    "slack",
    "fastify",
    "react",
    "dashboard",
    "mongodb",
    "postgres",
    "observability"
  ],
  "author": "Alexander Smith <ajs@alexandersmith.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexsmith2910/WatchDeck.git"
  },
  "bugs": {
    "url": "https://github.com/alexsmith2910/WatchDeck/issues"
  },
  "homepage": "https://www.watchdeck.dev/",
  "files": [
    "dist"
  ],
  "prettier": {},
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "mongodb": "^7.1.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.9.16",
    "ora": "^9.3.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "undici": "^8.1.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
