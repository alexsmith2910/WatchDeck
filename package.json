{
  "name": "watchdeck",
  "version": "0.1.0",
  "description": "Self-hosted endpoint monitoring toolkit for solo devs and small teams",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "watchdeck": "dist/bin/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup --config config/tsup.config.ts && copyfiles -u 1 \"src/templates/**/*\" dist",
    "build:dashboard": "vite build",
    "dev": "tsup --config config/tsup.config.ts --watch",
    "start": "node dist/bin/cli.js start",
    "lint": "eslint --config config/eslint.config.js src",
    "format": "prettier --write src"
  },
  "keywords": [
    "monitoring",
    "uptime",
    "endpoint",
    "self-hosted"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "prettier": {},
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@fastify/cors": "^11.2.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "mongodb": "^7.1.1",
    "next-themes": "^0.4.6",
    "ora": "^9.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
